#!/usr/bin/env bash
# tmax - persistent named-tab session manager

set -euo pipefail

SCRIPT="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT")"
SESSION="tmax"
SOCK="tmax"
CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tmax"
CONF="$CONF_DIR/tmux.conf"

COLORS=(colour1 colour2 colour3 colour4 colour5 colour6 colour208 colour82 colour165)
# Labels: h=home(0), then a-g(1-7), i-z(8-25) — 'h' skipped as it's reserved for home
LABELS=(h a b c d e f g i j k l m n o p q r s t u v w x y z)

pick_color() {
    local idx="$1"
    echo "${COLORS[$((idx % ${#COLORS[@]}))]}"
}

pick_label() {
    local idx="$1"
    echo "${LABELS[$idx]:-$idx}"
}

gen_conf() {
    mkdir -p "$CONF_DIR"
    cat > "$CONF" <<TMUXEOF
# tmax tmux config — generated by tmax, do not edit manually

set -g default-terminal "screen-256color"
set -g history-limit 50000
set -s escape-time 10
set -g base-index 0
set -g mouse on
setw -g automatic-rename off
set -g allow-rename off

# ── Status bar (always visible at top) ────────────────────────────────────────
set -g status on
set -g status-position top
set -g status-style "bg=colour235,fg=colour250"
set -g status-left "#[fg=colour6,bold] ◈ tmax #[fg=colour240]│ "
set -g status-left-length 20
set -g status-right "#[fg=colour240] %H:%M "
set -g status-right-length 10

# ── Window tab styling ─────────────────────────────────────────────────────────
set -g window-status-separator ""
set -g status-interval 1
set -g window-status-format         "#[fg=colour240]│#[fg=#{@tmax_color}] #{?#{m/r:^(bash|zsh|sh|fish|dash|ksh|tcsh|csh|tmax-home)$,#{pane_current_command}},,🔴 }#{@tmax_label}:#{window_name} "
set -g window-status-current-format "#[fg=colour240]│#[fg=colour235,bg=#{@tmax_color},bold] #{?#{m/r:^(bash|zsh|sh|fish|dash|ksh|tcsh|csh|tmax-home)$,#{pane_current_command}},,🔴 }#{@tmax_label}:#{window_name} #[fg=#{@tmax_color},bg=colour235,nobold]"

# ── No prefix — Alt keys only ─────────────────────────────────────────────────
unbind C-b
set -g prefix None

# ── Tab switching: Alt+h=home, Alt+a-z=tabs (h skipped) ──────────────────────
bind-key -n M-h select-window -t :=0
bind-key -n M-a select-window -t :=1
bind-key -n M-b select-window -t :=2
bind-key -n M-c select-window -t :=3
bind-key -n M-d select-window -t :=4
bind-key -n M-e select-window -t :=5
bind-key -n M-f select-window -t :=6
bind-key -n M-g select-window -t :=7
bind-key -n M-i select-window -t :=8
bind-key -n M-j select-window -t :=9

# ── Tab management ────────────────────────────────────────────────────────────
bind-key -n M-n command-prompt -p "Tab name:" "new-window -n '%%'"
bind-key -n M-r command-prompt -I "#{window_name}" -p "Rename tab:" "rename-window '%%'"
bind-key -n M-x if-shell '[ #{window_index} -ne 0 ]' \
    'confirm-before -p "Close \"#{window_name}\"? (y/n)" kill-window' \
    'detach-client'

# ── Auto-assign color when a new window is created ───────────────────────────
set-hook -g after-new-window 'run-shell "$SCRIPT assign-color #{session_name} #{window_index}"'
TMUXEOF
}

case "${1:-start}" in

    assign-color)
        session="${2:?session name required}"
        idx="${3:?window index required}"
        color=$(pick_color "$idx")
        label=$(pick_label "$idx")
        tmux -L "$SOCK" set-option -t "$session" -w @tmax_color "$color" 2>/dev/null || true
        tmux -L "$SOCK" set-option -t "$session" -w @tmax_start "$(date +%s)" 2>/dev/null || true
        tmux -L "$SOCK" set-option -t "$session" -w @tmax_label "$label" 2>/dev/null || true
        ;;

    start|"")
        gen_conf

        if ! tmux -L "$SOCK" has-session -t "$SESSION" 2>/dev/null; then
            tmux -L "$SOCK" -f "$CONF" new-session -d -s "$SESSION" -n "home"
            tmux -L "$SOCK" set-option -t "$SESSION":0 -w @tmax_color "colour6"
            tmux -L "$SOCK" set-option -t "$SESSION":0 -w @tmax_start "$(date +%s)"
            tmux -L "$SOCK" set-option -t "$SESSION":0 -w @tmax_label "h"
            tmux -L "$SOCK" send-keys -t "$SESSION":0 "$SCRIPT_DIR/tmax-home" Enter
        fi

        exec tmux -L "$SOCK" attach-session -t "$SESSION"
        ;;

    help|--help|-h)
        cat <<EOF
Usage: tmax [command]

Commands:
  start            Start or attach to session (default)
  install, -i      Full setup: generate config, apply to running session,
                   and add tmax to PATH if not already present.
                   Run once after cloning, and after any config changes.
  kill, -k         Kill the running session and all tabs
  help, --help     Show this help

EOF
        ;;

    install|-i)
        gen_conf
        tmux -L "$SOCK" source-file "$CONF" 2>/dev/null \
            && echo "tmax: config installed" \
            || echo "tmax: config generated (no session running)"

        if printf '%s\n' "${PATH//:/$'\n'}" | grep -qx "$SCRIPT_DIR"; then
            echo "tmax: already on PATH"
        else
            case "${SHELL##*/}" in
                zsh)  rc="$HOME/.zshrc"   ;;
                bash) rc="$HOME/.bashrc"  ;;
                *)    rc="$HOME/.profile" ;;
            esac
            if grep -q '# added by tmax' "$rc" 2>/dev/null; then
                echo "tmax: PATH entry already in $rc"
            else
                printf '\nexport PATH="$PATH:%s"  # added by tmax\n' "$SCRIPT_DIR" >> "$rc"
                echo "tmax: added to PATH in $rc"
                echo "tmax: run 'source $rc' or restart your shell"
            fi
        fi
        ;;

    kill|-k)
        tmux -L "$SOCK" kill-session -t "$SESSION" 2>/dev/null \
            && echo "tmax: session killed" \
            || echo "tmax: no session running"
        ;;

    *)
        echo "Usage: tmax [start|kill|assign-color <session> <idx>]" >&2
        exit 1
        ;;
esac
