#!/usr/bin/env bash
# tmax - persistent named-tab session manager

set -euo pipefail

SCRIPT="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT")"
SESSION="tmax"
SOCK="tmax"
CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tmax"
CONF="$CONF_DIR/tmux.conf"

COLORS=(colour1 colour2 colour3 colour4 colour5 colour6 colour208 colour82 colour165)
DARK_COLORS=(colour88 colour22 colour58 colour18 colour53 colour23 colour130 colour64 colour89)
# Labels: h=home(0), then a-g(1-7), i-z(8-25) — 'h' skipped as it's reserved for home
LABELS=(⌂ a b c d e f g i j k l m n o p q r s t u v w x y z)

pick_color() {
    local idx="$1"
    echo "${COLORS[$((idx % ${#COLORS[@]}))]}"
}

pick_dark_color() {
    local idx="$1"
    echo "${DARK_COLORS[$((idx % ${#DARK_COLORS[@]}))]}"
}

pick_label() {
    local idx="$1"
    echo "${LABELS[$idx]:-$idx}"
}

gen_conf() {
    mkdir -p "$CONF_DIR"
    local THIN_STRIP
    printf -v THIN_STRIP '▀%.0s' {1..300}
    cat > "$CONF" <<TMUXEOF
# tmax tmux config — generated by tmax, do not edit manually

set -g default-terminal "screen-256color"
set -g history-limit 50000
set -s escape-time 10
set -g base-index 0
set -g mouse on
setw -g automatic-rename off
set -g allow-rename off

# ── Status bar (always visible at top) ────────────────────────────────────────
set -g status 2
set -g status-position top
set -g status-style "bg=colour235,fg=colour250"
set -g status-left "#[fg=colour6,bold] ◈ tmax #[fg=colour240] "
set -g status-left-length 20
set -g status-right "#[fg=colour240] %H:%M "
set -g status-right-length 10

# ── Colored context border (thin strip below tab bar, matches current tab) ─────
# @tmax_current_color is a session option updated by after-select-window hook
set -g status-format[1] "#[fg=#{@tmax_current_color},bg=default]$THIN_STRIP"
set -g pane-active-border-style "fg=#{@tmax_current_color}"
set -g pane-border-style "fg=colour238"

# ── Window tab styling ─────────────────────────────────────────────────────────
set -g window-status-separator " "
set -g status-interval 1
set -g window-status-format         "#[fg=colour240]#[fg=#{@tmax_color},bg=#{@tmax_dark_color}] #{@tmax_label} #{?#{==:#{window_index},0},,#[bg=#{@tmax_color}\,fg=colour235] #{?#{m/r:^(bash|zsh|sh|fish|dash|ksh|tcsh|csh|tmax-home)$\,#{pane_current_command}},,#[fg=colour1]✸ #[fg=colour235]}#{window_name} }#[bg=colour235]"
set -g window-status-current-format "#[fg=colour240]#[fg=#{@tmax_color},bg=#{@tmax_dark_color},bold] #{@tmax_label} #{?#{==:#{window_index},0},,#[bg=#{@tmax_color}\,fg=colour235\,bold] #{?#{m/r:^(bash|zsh|sh|fish|dash|ksh|tcsh|csh|tmax-home)$\,#{pane_current_command}},,#[fg=colour1]✸ #[fg=colour235]}#{window_name} }#[bg=colour235,nobold]"

# ── No prefix — Alt keys only ─────────────────────────────────────────────────
unbind C-b
set -g prefix None

# ── Tab switching: Alt+h=home, Alt+a-z=tabs (h skipped) ──────────────────────
bind-key -n M-h select-window -t :=0
bind-key -n M-a select-window -t :=1
bind-key -n M-b select-window -t :=2
bind-key -n M-c select-window -t :=3
bind-key -n M-d select-window -t :=4
bind-key -n M-e select-window -t :=5
bind-key -n M-f select-window -t :=6
bind-key -n M-g select-window -t :=7
bind-key -n M-i select-window -t :=8
bind-key -n M-j select-window -t :=9

# ── Tab management ────────────────────────────────────────────────────────────
bind-key -n M-n command-prompt -p "Tab name:" "new-window -n '%%'"
bind-key -n M-r command-prompt -I "#{window_name}" -p "Rename tab:" "rename-window '%%'"
bind-key -n M-x if-shell '[ #{window_index} -ne 0 ]' \
    'confirm-before -p "Close \"#{window_name}\"? (y/n)" kill-window' \
    'detach-client'

# ── Auto-assign color when a new window is created ───────────────────────────
set-hook -g after-new-window       'run-shell "$SCRIPT assign-color #{session_name} #{window_index}"'
set-hook -g session-window-changed 'run-shell "$SCRIPT sync-current-color #{session_name}"'
TMUXEOF
}

case "${1:-start}" in

    assign-color)
        session="${2:?session name required}"
        idx="${3:?window index required}"
        # Collect colors already in use by other windows
        mapfile -t used_colors < <(tmux -L "$SOCK" list-windows -t "$session" -F "#{@tmax_color}" 2>/dev/null | grep -v '^$')
        # Shuffle palette and pick first unused color
        color=""
        dark_color=""
        mapfile -t indices < <(shuf -i 0-$((${#COLORS[@]}-1)))
        for i in "${indices[@]}"; do
            c="${COLORS[$i]}"
            in_use=0
            for u in "${used_colors[@]}"; do [[ "$u" == "$c" ]] && in_use=1 && break; done
            if [[ $in_use -eq 0 ]]; then
                color="$c"
                dark_color="${DARK_COLORS[$i]}"
                break
            fi
        done
        # Fallback if all colors exhausted
        [[ -z "$color" ]] && color=$(pick_color "$idx") && dark_color=$(pick_dark_color "$idx")
        label=$(pick_label "$idx")
        tmux -L "$SOCK" set-option -t "$session:$idx" -w @tmax_color "$color" 2>/dev/null || true
        tmux -L "$SOCK" set-option -t "$session:$idx" -w @tmax_dark_color "$dark_color" 2>/dev/null || true
        tmux -L "$SOCK" set-option -t "$session:$idx" -w @tmax_start "$(date +%s)" 2>/dev/null || true
        tmux -L "$SOCK" set-option -t "$session:$idx" -w @tmax_label "$label" 2>/dev/null || true
        tmux -L "$SOCK" set-option -t "$session" @tmax_current_color "$color" 2>/dev/null || true
        ;;

    set-current-color)
        session="${2:?session name required}"
        idx="${3:?window index required}"
        color=$(tmux -L "$SOCK" show-option -t "$session:$idx" -w @tmax_color 2>/dev/null | awk '{print $2}')
        tmux -L "$SOCK" set-option -t "$session" @tmax_current_color "$color" 2>/dev/null || true
        ;;

    sync-current-color)
        session="${2:?session name required}"
        idx=$(tmux -L "$SOCK" display-message -t "$session" -p "#{window_index}" 2>/dev/null)
        color=$(tmux -L "$SOCK" show-option -t "$session:$idx" -w @tmax_color 2>/dev/null | awk '{print $2}')
        tmux -L "$SOCK" set-option -t "$session" @tmax_current_color "$color" 2>/dev/null || true
        ;;

    start|"")
        gen_conf

        if ! tmux -L "$SOCK" has-session -t "$SESSION" 2>/dev/null; then
            tmux -L "$SOCK" -f "$CONF" new-session -d -s "$SESSION" -n "home"
            tmux -L "$SOCK" set-option -t "$SESSION":0 -w @tmax_color "colour6"
            tmux -L "$SOCK" set-option -t "$SESSION":0 -w @tmax_dark_color "colour23"
            tmux -L "$SOCK" set-option -t "$SESSION":0 -w @tmax_start "$(date +%s)"
            tmux -L "$SOCK" set-option -t "$SESSION":0 -w @tmax_label "⌂"
            tmux -L "$SOCK" send-keys -t "$SESSION":0 "$SCRIPT_DIR/tmax-home" Enter
        fi

        exec tmux -L "$SOCK" attach-session -t "$SESSION"
        ;;

    help|--help|-h)
        cat <<EOF
Usage: tmax [command]

Commands:
  start            Start or attach to session (default)
  install, -i      Full setup: generate config, apply to running session,
                   and add tmax to PATH if not already present.
                   Run once after cloning, and after any config changes.
  kill, -k         Kill the running session and all tabs
  help, --help     Show this help

EOF
        ;;

    install|-i)
        gen_conf
        tmux -L "$SOCK" source-file "$CONF" 2>/dev/null \
            && echo "tmax: config installed" \
            || echo "tmax: config generated (no session running)"

        # Backfill @tmax_dark_color and fix home label on any window that needs it
        if tmux -L "$SOCK" has-session -t "$SESSION" 2>/dev/null; then
            while IFS= read -r idx; do
                existing=$(tmux -L "$SOCK" show-option -t "$SESSION:$idx" -w @tmax_dark_color 2>/dev/null || true)
                if [[ -z "$existing" ]]; then
                    dark_color=$(pick_dark_color "$idx")
                    tmux -L "$SOCK" set-option -t "$SESSION:$idx" -w @tmax_dark_color "$dark_color" 2>/dev/null || true
                fi
                if [[ "$idx" -eq 0 ]]; then
                    tmux -L "$SOCK" set-option -t "$SESSION:0" -w @tmax_label "⌂" 2>/dev/null || true
                fi
            done < <(tmux -L "$SOCK" list-windows -t "$SESSION" -F '#{window_index}')
        fi

        if printf '%s\n' "${PATH//:/$'\n'}" | grep -qx "$SCRIPT_DIR"; then
            echo "tmax: already on PATH"
        else
            case "${SHELL##*/}" in
                zsh)  rc="$HOME/.zshrc"   ;;
                bash) rc="$HOME/.bashrc"  ;;
                *)    rc="$HOME/.profile" ;;
            esac
            if grep -q '# added by tmax' "$rc" 2>/dev/null; then
                echo "tmax: PATH entry already in $rc"
            else
                printf '\nexport PATH="$PATH:%s"  # added by tmax\n' "$SCRIPT_DIR" >> "$rc"
                echo "tmax: added to PATH in $rc"
                echo "tmax: run 'source $rc' or restart your shell"
            fi
        fi
        ;;

    kill|-k)
        tmux -L "$SOCK" kill-session -t "$SESSION" 2>/dev/null \
            && echo "tmax: session killed" \
            || echo "tmax: no session running"
        ;;

    *)
        echo "Usage: tmax [start|kill|assign-color <session> <idx>]" >&2
        exit 1
        ;;
esac
