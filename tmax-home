#!/usr/bin/env bash
# tmax-home - home tab display

SOCK="tmax"
SESSION="tmax"
POPUP_MODE="${TMAX_POPUP:-0}"

# ANSI codes â€” globals so they expand correctly inside "..." strings
R=$'\033[0m'           # reset
D=$'\033[2m'           # dim
B=$'\033[1m'           # bold
RED=$'\033[31m'
GREEN=$'\033[32m'
TBG=$'\033[48;5;235m'  # table background (inactive tab colour)
RT="${R}${TBG}"        # reset fg/bold then restore table bg

color_ansi() {
    case "$1" in
        colour1)   printf '\033[31m'       ;;
        colour2)   printf '\033[32m'       ;;
        colour3)   printf '\033[33m'       ;;
        colour4)   printf '\033[34m'       ;;
        colour5)   printf '\033[35m'       ;;
        colour6)   printf '\033[36m'       ;;
        colour208) printf '\033[38;5;208m' ;;
        colour82)  printf '\033[38;5;82m'  ;;
        colour165) printf '\033[38;5;165m' ;;
        *)         printf '\033[37m'       ;;
    esac
}

# Bright foreground colour â†’ ANSI background (for label badge)
colour_bg() {
    case "$1" in
        colour1)   printf '\033[41m'         ;;
        colour2)   printf '\033[42m'         ;;
        colour3)   printf '\033[43m'         ;;
        colour4)   printf '\033[44m'         ;;
        colour5)   printf '\033[45m'         ;;
        colour6)   printf '\033[46m'         ;;
        colour208) printf '\033[48;5;208m'   ;;
        colour82)  printf '\033[48;5;82m'    ;;
        colour165) printf '\033[48;5;165m'   ;;
        *)         printf '\033[40m'         ;;
    esac
}


enable_mouse()  { printf '\033[?1000h\033[?1006h'; }
disable_mouse() { printf '\033[?1000l\033[?1006l'; }

trap '' INT TERM

_refresh_status() {
    while true; do
        tmux -L "$SOCK" refresh-client -S 2>/dev/null || true
        sleep 0.2
    done
}
_refresh_status &
_REFRESH_PID=$!
trap 'disable_mouse; kill "$_REFRESH_PID" 2>/dev/null' EXIT

_last_frame=""
_WIN_ORDER=()
_WIN_ROW_START=3  # pane row (1-indexed) of first window entry
declare -A _WIN_WAS_BUSY  # idx -> "1" if was busy last draw
declare -A _WIN_DONE      # idx -> "1" if done and unvisited

draw() {
    local cols now windows box_w name_w h_inner
    cols=$(tput cols 2>/dev/null || echo 80)
    now=$(date +%s)

    windows=$(tmux -L "$SOCK" list-windows -t "$SESSION" \
        -F "#{window_index}|#{window_name}|#{@tmax_color}|#{window_active}|#{@tmax_start}|#{pane_current_command}|#{@tmax_label}|#{@tmax_bg_tint}|#{@tmax_indicator}" \
        2>/dev/null) || windows=""

    # Pre-pass: detect busyâ†’idle transitions on non-active windows
    local windows_aug=""
    while IFS='|' read -r idx name color active start_ts cmd label bg_tint indicator; do
        local done_flag=0
        if [[ "$idx" != "0" ]]; then
            local is_busy=0
            case "$cmd" in bash|zsh|sh|fish|dash|ksh|tcsh|csh|tmax-home) ;; *) is_busy=1 ;; esac

            if [[ "$active" == "1" ]]; then
                # User is on this tab â€” clear done and error indicator
                if [[ "${_WIN_DONE[$idx]:-0}" == "1" ]]; then
                    tmux -L "$SOCK" set-option -t "$SESSION:$idx" -w @tmax_done "" 2>/dev/null || true
                fi
                if [[ -n "$indicator" ]]; then
                    tmux -L "$SOCK" set-option -t "$SESSION:$idx" -w @tmax_indicator "" 2>/dev/null || true
                    indicator=""
                fi
                _WIN_DONE[$idx]=0
            elif [[ $is_busy -eq 0 && "${_WIN_WAS_BUSY[$idx]:-}" == "1" ]]; then
                # Transitioned busyâ†’idle while user was elsewhere
                tmux -L "$SOCK" set-option -t "$SESSION:$idx" -w @tmax_done "1" 2>/dev/null || true
                _WIN_DONE[$idx]=1
            fi
            _WIN_WAS_BUSY[$idx]=$is_busy
            done_flag="${_WIN_DONE[$idx]:-0}"
        fi
        windows_aug+="${idx}|${name}|${color}|${active}|${start_ts}|${cmd}|${label}|${bg_tint}|${done_flag}|${indicator}"$'\n'
    done <<< "$windows"
    [[ -n "$windows_aug" ]] && windows_aug="${windows_aug%$'\n'}"

    _WIN_ORDER=()
    if [[ -n "$windows_aug" ]]; then
        while IFS='|' read -r idx _rest; do
            [[ "$idx" == "0" ]] && continue
            _WIN_ORDER+=("$idx")
        done <<< "$windows_aug"
    fi

    box_w=$(( cols - 4 ))
    (( box_w > 58 )) && box_w=58
    (( box_w < 30 )) && box_w=30
    # row: â”‚ sp label(3) sp name(N) sp sp status(4) sp sp uptime(5) sp â”‚ = 21+N
    name_w=$(( box_w - 21 ))
    (( name_w < 6 )) && name_w=6
    h_inner=$(printf 'â”€%.0s' $(seq 1 $(( box_w - 2 ))))

    local frame
    frame=$(
        buf=$'\033[?25l\033[H'
        if [[ "$POPUP_MODE" == "1" ]]; then
            printf -v _x_str "%${box_w}s" "âś•"
            buf+="  ${D}${_x_str}${R}"$'\033[K\n'
        else
            buf+=$'\n\033[K'
        fi
        buf+="  ${D}â•­${h_inner}â•®${R}"$'\033[K\n'

        while IFS='|' read -r idx name color active start_ts cmd label bg_tint done_flag indicator; do
            [[ "$idx" == "0" ]] && continue

            lbl_bg=$(colour_bg "$color")

            if [[ "$start_ts" =~ ^[0-9]+$ ]]; then
                elapsed=$(( now - start_ts ))
                printf -v runtime '%02d:%02d' $(( elapsed / 3600 )) $(( (elapsed % 3600) / 60 ))
            else
                runtime='--:--'
            fi

            is_busy=0
            case "$cmd" in bash|zsh|sh|fish|dash|ksh|tcsh|csh|tmax-home) ;; *) is_busy=1 ;; esac

            if [[ "$active" == 1 ]]; then
                status="${D}here${RT}"
                row_text="${B}"
            elif [[ -n "$indicator" ]]; then
                status="${RED}â– ${RT}   "
                row_text=""
            elif [[ "$done_flag" == "1" ]]; then
                status="${GREEN}âś“${RT}   "
                row_text=""
            elif (( is_busy )); then
                status="${RED}busy${RT}"
                row_text=""
            else
                status="    "
                row_text="${D}"
            fi

            disp_name="$name"
            (( ${#name} > name_w )) && disp_name="${name:0:$(( name_w - 1 ))}â€¦"
            printf -v disp_name "%-${name_w}s" "$disp_name"

            # Center label in 3 chars
            len=${#label}
            lpad=$(( (3 - len) / 2 ))
            rpad=$(( 3 - len - lpad ))
            printf -v disp_label "%${lpad}s%s%${rpad}s" "" "$label" ""

            buf+="  ${D}â”‚${R}${TBG} ${lbl_bg}${B}${disp_label}${RT} ${row_text}${disp_name}${RT}  ${status}  ${D}${runtime}${RT} ${R}${D}â”‚${R}"$'\033[K\n'
        done <<< "$windows_aug"

        buf+="  ${D}â•°${h_inner}â•Ż${R}"$'\033[K\n'
        buf+=$'\n\033[K'

        rule=$(printf 'â”€%.0s' $(seq 1 $(( box_w ))))
        buf+="  ${D}${rule}${R}"$'\033[K\n'
        buf+=$'\033[K\n'
        if [[ "$POPUP_MODE" == "1" ]]; then
            buf+="  ${D}1-9${R} jump  ${D}Â·${R}  ${D}q${R} close"$'\033[K\n'
        else
            buf+="  Hold ${B}Alt${R} for shortcuts from any tab."$'\033[K\n'
            buf+=$'\033[K\n'
            if (( cols < 58 )); then
                buf+="  ${D}1-9${R} jump  ${D}Â·${R}  ${D}q${R} detach  ${D}Â·${R}  ${D}M-n${R} new"$'\033[K\n'
            else
                buf+="  ${D}M-n${R} new  ${D}Â·${R}  ${D}M-r${R} rename  ${D}Â·${R}  ${D}M-x${R} close  ${D}Â·${R}  ${D}1-9${R} jump  ${D}Â·${R}  ${D}q${R} detach"$'\033[K\n'
            fi
        fi

        printf '%s' "$buf"
        printf '\033[J'
    )

    [[ "$frame" == "$_last_frame" ]] && return
    _last_frame="$frame"
    printf '%s' "$frame"
}

switch_to_tab() {
    local idx="$1"
    [[ "$idx" == "0" ]] && return
    tmux -L "$SOCK" select-window -t "$SESSION:$idx" 2>/dev/null || true
    [[ "$POPUP_MODE" == "1" ]] && exit 0
}

handle_mouse() {
    local seq="$1" content btn col row final
    [[ "$seq" == $'\033['* ]] || return
    content="${seq:2}"
    [[ "$content" =~ ^'<'([0-9]+)';'([0-9]+)';'([0-9]+)([Mm]) ]] || return
    btn="${BASH_REMATCH[1]}" col="${BASH_REMATCH[2]}" row="${BASH_REMATCH[3]}" final="${BASH_REMATCH[4]}"
    [[ "$final" == "m" || "$btn" != "0" ]] && return
    list_pos=$(( row - _WIN_ROW_START ))
    if (( list_pos >= 0 && list_pos < ${#_WIN_ORDER[@]} )); then
        switch_to_tab "${_WIN_ORDER[$list_pos]}"
    elif [[ "$POPUP_MODE" == "1" ]]; then
        exit 0
    fi
}

tput clear 2>/dev/null || printf '\033[2J\033[H'
enable_mouse

SELF="$(readlink -f "${BASH_SOURCE[0]}")"
SELF_MTIME=$(stat -c %Y "$SELF" 2>/dev/null)

while true; do
    draw

    key=""
    IFS= read -r -s -N 1 -t 0.2 key 2>/dev/null || true

    if [[ -n "$key" ]]; then
        if [[ "$key" == $'\033' ]]; then
            rest="" c=""
            IFS= read -r -s -N 1 -t 0.05 c 2>/dev/null || true
            rest="$c"
            if [[ "$c" == "[" ]]; then
                while IFS= read -r -s -N 1 -t 0.05 c 2>/dev/null; do
                    rest+="$c"
                    [[ "$c" =~ [A-Za-z] ]] && break
                done
            fi
            handle_mouse $'\033'"$rest"
        else
            case "$key" in
                q|Q) printf '\033[?25h'; disable_mouse
                     if [[ "$POPUP_MODE" == "1" ]]; then exit 0
                     else tmux -L "$SOCK" detach-client; fi ;;
                [1-9])
                    target=$(tmux -L "$SOCK" list-windows -t "$SESSION" \
                        -F "#{window_index}|#{@tmax_label}" 2>/dev/null \
                        | awk -F'|' -v k="$key" '$2==k{print $1; exit}')
                    [[ -n "$target" ]] && switch_to_tab "$target"
                    ;;
            esac
        fi
    fi

    new_mtime=$(stat -c %Y "$SELF" 2>/dev/null)
    if [[ "$new_mtime" != "$SELF_MTIME" ]]; then
        disable_mouse
        exec "$SELF"
    fi
done
