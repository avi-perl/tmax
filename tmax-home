#!/usr/bin/env bash
# tmax-home - home tab display

SOCK="tmax"
SESSION="tmax"

color_ansi() {
    case "$1" in
        colour1)   printf '\033[31m'       ;;  # red
        colour2)   printf '\033[32m'       ;;  # green
        colour3)   printf '\033[33m'       ;;  # yellow
        colour4)   printf '\033[34m'       ;;  # blue
        colour5)   printf '\033[35m'       ;;  # magenta
        colour6)   printf '\033[36m'       ;;  # cyan
        colour208) printf '\033[38;5;208m' ;;  # orange
        colour82)  printf '\033[38;5;82m'  ;;  # lime
        colour165) printf '\033[38;5;165m' ;;  # purple
        *)         printf '\033[37m'       ;;  # white fallback
    esac
}

trap '' INT TERM

# Background loop that forces status bar repaints faster than status-interval allows
_refresh_status() {
    while true; do
        tmux -L "$SOCK" refresh-client -S 2>/dev/null || true
        sleep 0.2
    done
}
_refresh_status &
_REFRESH_PID=$!
trap 'kill "$_REFRESH_PID" 2>/dev/null' EXIT

_last_frame=""

draw() {
    # Build the entire frame before touching the terminal, then write atomically
    local frame
    frame=$(
        cols=$(tput cols 2>/dev/null || echo 80)
        now=$(date +%s)
        line=$(printf '─%.0s' $(seq 1 $((cols - 4))))

        windows=$(tmux -L "$SOCK" list-windows -t "$SESSION" \
            -F "#{window_index}|#{window_name}|#{@tmax_color}|#{window_active}|#{@tmax_start}|#{pane_current_command}|#{@tmax_label}" 2>/dev/null) || {
            printf '\033[?25l\033[H'
            printf "\n\033[K"
            printf "  \033[2m(session not found)\033[0m\033[K\n"
            printf '\033[J'
            exit 0
        }

        buf=''
        buf+=$'\033[?25l\033[H'
        buf+=$'\n\033[K'

        while IFS='|' read -r idx name color active start_ts cmd label; do
            ansi=$(color_ansi "$color")
            runtime=""

            if [[ "$start_ts" =~ ^[0-9]+$ ]]; then
                elapsed=$(( now - start_ts ))
                runtime=$(printf "%02d:%02d" $(( elapsed / 3600 )) $(( (elapsed % 3600) / 60 )))
            fi

            busy=""
            case "$cmd" in
                bash|zsh|sh|fish|dash|ksh|tcsh|csh|tmax-home) ;;
                *) busy="1" ;;
            esac

            row="  ${ansi}●"$'\033[0m'" "
            [ -n "$busy" ] && row+=$'\033[31m✸\033[0m '"  "

            if [ "$active" = "1" ]; then
                row+=$'\033[1m'"${label}: ${name}"$'\033[0m  \033[2m← you are here\033[0m'
            else
                row+="${label}: ${name}"
                [ "$idx" != "0" ] && row+=$'  \033[2m'"Alt+${label}"$'\033[0m'
            fi

            [ -n "$runtime" ] && row+=$'  \033[2m'"${runtime}"$'\033[0m'
            row+=$'\033[K\n'
            buf+="$row"
        done <<< "$windows"

        buf+=$'\033[K\n'
        buf+="  "$'\033[2m'"${line}"$'\033[0m\033[K\n'
        buf+=$'\033[K\n'
        buf+=$'  \033[2mAlt+n\033[0m  new    \033[2mAlt+r\033[0m  rename    \033[2mAlt+x\033[0m  close    \033[2mAlt+a-z\033[0m  jump    \033[2ma-z\033[0m  close tab    \033[2mq\033[0m  exit to shell\033[K\n'
        buf+=$'\033[K\n'
        printf '%s' "$buf"
        printf '\033[J'
    )

    # Only write to terminal if frame changed
    [[ "$frame" == "$_last_frame" ]] && return
    _last_frame="$frame"
    printf '%s' "$frame"
}

close_tab() {
    local idx="$1"
    local name
    name=$(tmux -L "$SOCK" list-windows -t "$SESSION" \
        -F "#{window_index}|#{window_name}" 2>/dev/null \
        | awk -F'|' -v i="$idx" '$1==i{print $2}')
    [ -z "$name" ] && return

    printf '\033[?25h'
    printf '  Close tab %s "%s"? [y/N] ' "$idx" "$name"
    local confirm
    read -r -n 1 confirm 2>/dev/null
    printf '\n\033[?25l'

    if [[ "$confirm" =~ ^[yY]$ ]]; then
        tmux -L "$SOCK" kill-window -t "$SESSION:$idx" 2>/dev/null || true
    fi
}

# One-time full clear before entering the no-flash loop
tput clear 2>/dev/null || printf '\033[2J\033[H'

SELF="$(readlink -f "${BASH_SOURCE[0]}")"
SELF_MTIME=$(stat -c %Y "$SELF" 2>/dev/null)

while true; do
    draw
    if read -r -s -n 1 -t 0.2 key 2>/dev/null; then
        case "$key" in
            q|Q) printf '\033[?25h'; tmux -L "$SOCK" detach-client ;;
            [a-g]|[i-z])
                # Convert letter label back to window index (a-g=1-7, i-z=8-25)
                local ord
                ord=$(printf '%d' "'$key")
                if [ "$ord" -le 103 ]; then  # a(97)-g(103)
                    close_tab $((ord - 96))
                else                         # i(105)-z(122), h skipped
                    close_tab $((ord - 97))
                fi
                ;;
        esac
    fi
    # Hot-reload: re-exec if script was modified
    new_mtime=$(stat -c %Y "$SELF" 2>/dev/null)
    if [[ "$new_mtime" != "$SELF_MTIME" ]]; then
        exec "$SELF"
    fi
done
